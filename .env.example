# Private Dify Marketplace - Environment Variables

# Admin token for protecting update and reindex endpoints
MARKETPLACE_ADMIN_TOKEN=

# Port the service listens on
MARKETPLACE_PORT=3001

# Host to bind to
MARKETPLACE_HOST=0.0.0.0

# Path to the SQLite index database (leave empty to use in-memory index only)
MARKETPLACE_INDEX_DB_PATH=

# Validate the SQLite index against the filesystem on startup
MARKETPLACE_VALIDATE_INDEX_DB=true

# Optional sync command to run on startup (e.g., git pull)
MARKETPLACE_SYNC_CMD=

# Timeout for the sync command in seconds
MARKETPLACE_SYNC_TIMEOUT_SECONDS=600

# Comma-separated list of allowed CORS origins
MARKETPLACE_CORS_ALLOW_ORIGINS=
